#, kde-format
msgid ""
"Cannot interact with flatpak resources without the flatpak backend %1. "
"Please install it first."
msgstr ""
"flatpak ئارقا ئۇچ پىروگراممىسى %1 كەم، flatpak مەنبەسى بىلەن "
"تەسىرلىشەلمەيدۇ. ئالدى بىلەن ئۇنى ئورنىتىڭ."

#: discover/DiscoverObject.cpp:354
#, kde-format
msgid "Could not open %1"
msgstr "%1 نى ئاچالمىدى"

#: discover/DiscoverObject.cpp:419
#, kde-format
