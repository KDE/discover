#, kde-kuit-format
msgctxt ""
"@info %1 is an additional error reference and %3 is the name of the "
"operating system"
msgid ""
"(No entry for %1)<nl/><nl/>Please <link url='%2'>report this issue to %3.</"
"link>"
msgstr ""
